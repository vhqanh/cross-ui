{
  "name": "@aioz/cross-ui",
  "version": "0.1.0",
  "description": "Shared UI component kit built with Tamagui — works on React Native & Web",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "require": "./dist/tokens/index.js",
      "import": "./dist/tokens/index.mjs",
      "default": "./dist/tokens/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec tsup && pnpm exec tsc -p tsconfig.build.json",
    "dev": "pnpm exec tsup --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-web": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  },
  "dependencies": {
    "@tamagui/animations-react-native": "^2.0.0-rc.41",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/core": "^2.0.0-rc.41",
    "@tamagui/font-inter": "^2.0.0-rc.41",
    "@tamagui/themes": "^2.0.0-rc.41",
    "tamagui": "^2.0.0-rc.41"
  },
  "devDependencies": {
    "@rollup/plugin-inject": "^5.0.5",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "storybook": "^8.6.14",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.2"
  }
}
